#!/bin/bash
set -euo pipefail

# Expected answers: affected system; problematic Kafka metric; root cause
EXPECTED_SERVICE="kafka"
EXPECTED_ISSUE_TYPE="consumer lag"
EXPECTED_ROOT_CAUSE="kafka queue problems"

ALT_SERVICE_ANSWERS=("accountingservice" "accounting service" "accounting" "frauddetectionservice" "fraud detection" "message queue")
ALT_ISSUE_ANSWERS=("queue lag" "message lag" "kafka lag" "lag" "consumer backlog" "queue backlog")
ALT_ROOT_CAUSE_ANSWERS=("kafkaqueueproblems" "kafka overload" "producer overload" "message flood" "queue overflow" "10x message rate" "feature flag")

normalize() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | xargs
}

check_answer() {
    local answer="$1"
    local expected="$2"
    shift 2
    local alternatives=("$@")

    local normalized_answer=$(normalize "$answer")
    local normalized_expected=$(normalize "$expected")

    if [[ "$normalized_answer" == "$normalized_expected" ]]; then
        return 0
    fi

    for alt in "${alternatives[@]}"; do
        local normalized_alt=$(normalize "$alt")
        if [[ "$normalized_answer" == "$normalized_alt" ]]; then
            return 0
        fi
    done

    return 1
}

ANSWER_FILE="/tmp/answers.json"
if [[ ! -f "$ANSWER_FILE" ]]; then
    fail-message "❌ No answers submitted yet. Please enter your answers in the Check terminal."
    exit 1
fi

FULL_ANSWER=$(jq -r '.answer // empty' "$ANSWER_FILE")

if [[ -z "$FULL_ANSWER" ]]; then
    fail-message "❌ Answer cannot be empty."
    exit 1
fi

IFS=';' read -ra ANSWERS <<< "$FULL_ANSWER"

if [[ ${#ANSWERS[@]} -ne 3 ]]; then
    fail-message "❌ Invalid format. Please enter 3 answers separated by semi-colons: service; issue type; root cause"
    exit 1
fi

SERVICE_ANSWER=$(echo "${ANSWERS[0]}" | xargs)
ISSUE_TYPE_ANSWER=$(echo "${ANSWERS[1]}" | xargs)
ROOT_CAUSE_ANSWER=$(echo "${ANSWERS[2]}" | xargs)

if [[ -z "$SERVICE_ANSWER" ]] || [[ -z "$ISSUE_TYPE_ANSWER" ]] || [[ -z "$ROOT_CAUSE_ANSWER" ]]; then
    fail-message "❌ All three parts must be filled. Format: service; issue type; root cause"
    exit 1
fi

SERVICE_CORRECT=false
ISSUE_TYPE_CORRECT=false
ROOT_CAUSE_CORRECT=false

check_answer "$SERVICE_ANSWER" "$EXPECTED_SERVICE" "${ALT_SERVICE_ANSWERS[@]}" && SERVICE_CORRECT=true
check_answer "$ISSUE_TYPE_ANSWER" "$EXPECTED_ISSUE_TYPE" "${ALT_ISSUE_ANSWERS[@]}" && ISSUE_TYPE_CORRECT=true
check_answer "$ROOT_CAUSE_ANSWER" "$EXPECTED_ROOT_CAUSE" "${ALT_ROOT_CAUSE_ANSWERS[@]}" && ROOT_CAUSE_CORRECT=true

if $SERVICE_CORRECT && $ISSUE_TYPE_CORRECT && $ROOT_CAUSE_CORRECT; then
    echo "✅ All answers correct! Incident resolved."
    echo "🎯 Root cause: $SERVICE_ANSWER experiencing $ISSUE_TYPE_ANSWER due to $ROOT_CAUSE_ANSWER"
    exit 0
else
    CORRECT_COUNT=0
    $SERVICE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $ISSUE_TYPE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $ROOT_CAUSE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    fail-message "❌ Not all answers are correct ($CORRECT_COUNT/3). Check your investigation and try again."
    exit 1
fi
