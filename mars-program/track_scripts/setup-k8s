#!/bin/bash
set -euo pipefail

# --- HOST CHECKS & CONFIG ---
echo "Ensure host and env are ready..."
until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]
do
    sleep 2
done

# Store the working directory before cloning
WORK_DIR="$(pwd)"

# Set up parameters (see config.yml for other env variables)
export TF_VAR_newrelic_api_key="${MARS_PARENT_API_KEY}"
export TF_VAR_subaccount_name="${NR_SUBACCOUNT_NAME_PREFIX} ${INSTRUQT_PARTICIPANT_ID}"
export TF_VAR_readonly_user_name="${INSTRUQT_PARTICIPANT_ID} - User"
export TF_VAR_readonly_user_email="${INSTRUCTOR_EMAIL_HANDLE}+${INSTRUQT_PARTICIPANT_ID}@${INSTRUCTOR_EMAIL_DOMAIN}"

echo "✅ Host and env are ready!"

# --- INSTALL DEPENDENCIES (Terraform, jq, curl, go) ---
echo "Installing dependencies..."

# Add official HashiCorp's repo
sudo apt-get install -y gnupg software-properties-common
wget -O- https://apt.releases.hashicorp.com/gpg | gpg --dearmor | sudo tee /usr/share/keyrings/hashicorp-archive-keyring.gpg > /dev/null
gpg --no-default-keyring --keyring /usr/share/keyrings/hashicorp-archive-keyring.gpg --fingerprint
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(grep -oP '(?<=UBUNTU_CODENAME=).*' /etc/os-release || lsb_release -cs) main" | sudo tee /etc/apt/sources.list.d/hashicorp.list

# Update apt and install dependencies
sudo apt-get update
sudo apt-get install -y terraform curl jq
echo "✅ Dependencies installed!"

# --- CLONE CHARTS LOCALLY AND PACKAGE DEPENDENCIES --- (TODO: should not need this if timeouts on https://release-assets.githubusercontent.com/ weren't happening)
# Clone the main Helm chart repos at specific release tags for stability
cd "${WORK_DIR}"
echo "Cloning Helm chart repositories..."
git clone --branch nr-k8s-otel-collector-0.10.9 --depth 1 https://github.com/newrelic/helm-charts.git
git clone --branch opentelemetry-demo-0.40.5 --depth 1 https://github.com/open-telemetry/opentelemetry-helm-charts.git

# Clone dependency repos at specific release tags (even for disabled charts, Helm expects the .tgz files to exist)
echo "Cloning dependency chart repositories..."
git clone --branch prometheus-28.13.0 --depth 1 https://github.com/prometheus-community/helm-charts.git prometheus-charts
git clone --branch jaeger-4.5.0 --depth 1 https://github.com/jaegertracing/helm-charts.git jaeger-charts
git clone --branch opensearch-3.5.0 --depth 1 https://github.com/opensearch-project/helm-charts.git opensearch-charts
git clone --depth 1 https://github.com/bitnami/charts.git bitnami-charts

# Clone grafana from the new community location
git clone --branch grafana-11.3.0 --depth 1 https://github.com/grafana-community/helm-charts.git grafana-charts

# Package all dependencies locally
echo "Packaging chart dependencies locally..."
mkdir -p "${WORK_DIR}/helm-charts/charts/nr-k8s-otel-collector/charts"
mkdir -p "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo/charts"
mkdir -p "${WORK_DIR}/jaeger-charts/charts/jaeger/charts"
mkdir -p "${WORK_DIR}/prometheus-charts/charts/prometheus/charts"

# For nr-k8s-otel-collector: common-library + kube-state-metrics
helm package "${WORK_DIR}/helm-charts/library/common-library" -d "${WORK_DIR}/helm-charts/charts/nr-k8s-otel-collector/charts"
helm package "${WORK_DIR}/prometheus-charts/charts/kube-state-metrics" -d "${WORK_DIR}/helm-charts/charts/nr-k8s-otel-collector/charts"

# Package bitnami common for jaeger first (jaeger depends on it)
helm package "${WORK_DIR}/bitnami-charts/bitnami/common" -d "${WORK_DIR}/jaeger-charts/charts/jaeger/charts"

# Package prometheus sub-dependencies (prometheus depends on these)
helm package "${WORK_DIR}/prometheus-charts/charts/alertmanager" -d "${WORK_DIR}/prometheus-charts/charts/prometheus/charts"
helm package "${WORK_DIR}/prometheus-charts/charts/kube-state-metrics" -d "${WORK_DIR}/prometheus-charts/charts/prometheus/charts"
helm package "${WORK_DIR}/prometheus-charts/charts/prometheus-node-exporter" -d "${WORK_DIR}/prometheus-charts/charts/prometheus/charts"
helm package "${WORK_DIR}/prometheus-charts/charts/prometheus-pushgateway" -d "${WORK_DIR}/prometheus-charts/charts/prometheus/charts"

# For opentelemetry-demo: all dependencies (even disabled ones must be present for Helm)
helm package "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-collector" -d "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo/charts"
helm package "${WORK_DIR}/jaeger-charts/charts/jaeger" -d "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo/charts"
helm package "${WORK_DIR}/prometheus-charts/charts/prometheus" -d "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo/charts"
helm package "${WORK_DIR}/grafana-charts/charts/grafana" -d "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo/charts"
helm package "${WORK_DIR}/opensearch-charts/charts/opensearch" -d "${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo/charts"

echo "✅ All charts and dependencies packaged locally!"

# --- CLONE REPO AND SETUP CONFIG ---
echo "Cloning New Relic's OpenTelemetry Demo..."
git clone https://github.com/newrelic/opentelemetry-demo
echo "✅ OpenTelemetry Demo cloned!"

# --- CREATE NR SUBACCOUNT ---
echo "Creating New Relic sub-account"
cd "${WORK_DIR}/opentelemetry-demo/newrelic/scripts"
./install-nr-account.sh

export TF_VAR_newrelic_account_id=$(cd "${WORK_DIR}/opentelemetry-demo/newrelic/terraform/nr_account" && terraform output -raw account_id)
export NEW_RELIC_LICENSE_KEY=$(cd "${WORK_DIR}/opentelemetry-demo/newrelic/terraform/nr_account" && terraform output -raw license_key)

echo "✅ Subaccount created!"

# --- CREATE BROWSER APP --
echo "Creating New Relic Browser app..."
echo "Waiting 60 seconds to avoid account inconsistency..." # (TODO: investigate potential check to avoid "Error: Validation failed: Name should be unique" if app is created too early)
sleep 60
cd "${WORK_DIR}/opentelemetry-demo/newrelic/terraform/nr_browser"
terraform init
terraform apply -auto-approve

# Get the outputs from the browser terraform module
BROWSER_LICENSE_KEY=$(terraform output -raw browser_license_key)
BROWSER_JS_CONFIG=$(terraform output -raw browser_js_config)

# Parse the JSON config to extract individual values from loader_config
APP_ID=$(echo "$BROWSER_JS_CONFIG" | jq -r '.loader_config.applicationID')
TRUST_KEY=$(echo "$BROWSER_JS_CONFIG" | jq -r '.loader_config.trustKey')
AGENT_ID=$(echo "$BROWSER_JS_CONFIG" | jq -r '.loader_config.agentID')
echo "✅ Browser app created!"

# --- PATCH TEMPLATE --- (TODO: when we move to Go CLI this won't be needed)
echo "Patching nr-browser.yaml template..."
TEMPLATE_FILE="${WORK_DIR}/opentelemetry-demo/newrelic/k8s/helm/nr-browser.yaml.tmpl"
OUTPUT_FILE="${WORK_DIR}/opentelemetry-demo/newrelic/k8s/helm/nr-browser.yaml"
sed \
  -e "s|{{ .LicenseKey }}|${BROWSER_LICENSE_KEY}|g" \
  -e "s|{{ .AppID }}|${APP_ID}|g" \
  -e "s|{{ .AccountID }}|${TF_VAR_newrelic_account_id}|g" \
  -e "s|{{ .TrustKey }}|${TRUST_KEY}|g" \
  -e "s|{{ .AgentID }}|${AGENT_ID}|g" \
  "${TEMPLATE_FILE}" > "${OUTPUT_FILE}"
echo "✅ nr-browser.yaml template patched!"

# --- PATCH INSTALL-K8S.SH TO SUPPORT BROWSER OVERRIDE --- (TODO: when we move to Go CLI this won't be needed)
echo "Patching install-k8s.sh to support browser configuration override..."
INSTALL_SCRIPT="${WORK_DIR}/opentelemetry-demo/newrelic/scripts/install-k8s.sh"
cp "${INSTALL_SCRIPT}" "${INSTALL_SCRIPT}.bak"
awk '
# Add additional_values_file parameter after is_openshift line
/local is_openshift=\$\{6:-\}/ {
    print $0
    print "  local additional_values_file=\${7:-}  # Optional: Additional values file for overrides"
    next
}

/# Shift away the first 5 required arguments, then check if 6th exists before shifting it/ {
    print $0
    getline  # Read next line: shift 5
    print $0
    getline  # Read next line: if [ $# -gt 0 ]; then
    print $0
    getline  # Read next line: shift  # Shift away the 6th argument...
    print $0
    getline  # Read next line: fi
    print $0
    print "  if [ $" "# -gt 0 ]; then"
    print "    shift  # Shift away the 7th argument (additional_values_file) if it exists"
    print "  fi"
    next
}

# Add logic to include additional values file after the main values file
/local helm_args=\(.*-f "\$values_file"\)/ {
    print $0
    print ""
    print "  # Add additional values file if provided"
    print "  if [ -n \"\$additional_values_file\" ]; then"
    print "    helm_args+=(-f \"\$additional_values_file\")"
    print "  fi"
    next
}

# Modify the OTEL demo installation call to include browser yaml
/install_or_upgrade_chart "\$OTEL_DEMO_RELEASE_NAME"/ {
    in_otel_call = 1
}

# Add the browser yaml as 7th parameter after IS_OPENSHIFT_CLUSTER line in the OTEL call
in_otel_call && /"\$IS_OPENSHIFT_CLUSTER"/ {
    # Add backslash to continue the line, then add the browser yaml parameter
    print $0 " \\"
    print "  \"../k8s/helm/nr-browser.yaml\""
    in_otel_call = 0
    next
}

# Print all other lines as-is
{ print }
' "${INSTALL_SCRIPT}.bak" > "${INSTALL_SCRIPT}"

chmod +x "${INSTALL_SCRIPT}"
echo "✅ install-k8s.sh patched!"

# --- CHANGE install-k8s.sh FOR CLONED REPOS --- (TODO: should not need this if timeouts on https://release-assets.githubusercontent.com/ weren't happening)
# Intercept the scripts: Find and replace the remote chart references with absolute local paths
# (This uses your current directory $PWD so Helm knows exactly where to look)
SCRIPT_PATH="${WORK_DIR}/opentelemetry-demo/newrelic/scripts/install-k8s.sh"

echo "Patching $SCRIPT_PATH to use local charts..."
sed -i "s|newrelic/nr-k8s-otel-collector|${WORK_DIR}/helm-charts/charts/nr-k8s-otel-collector|g" "$SCRIPT_PATH"
sed -i "s|open-telemetry/opentelemetry-demo|${WORK_DIR}/opentelemetry-helm-charts/charts/opentelemetry-demo|g" "$SCRIPT_PATH"

# --- DEPLOY DEMO TO KUBERNETES ---
echo "Deploying OpenTelemetry Demo..."
echo "Waiting for Kubernetes API..."
# Loop until the 'default' service account exists (sign that the API is up)
until kubectl get serviceaccount default &> /dev/null; do
  sleep 2
done
echo "✅ Cluster is ready!"

cd "${WORK_DIR}/opentelemetry-demo/newrelic/scripts"
./install-k8s.sh

echo "Waiting for all pods to be ready..."
sleep 60 # Wait for pod creation to start
kubectl wait --for=condition=ready pod --all -n opentelemetry-demo --timeout=600s || true
echo "✅ OpenTelemetry Demo is fully deployed and ready!"

echo "Waiting 5 minutes for data to show up in New Relic..."
sleep 300 # Wait for entities to be created in New Relic (TODO: make this an actual GraphQL check)

echo "✅ Entities should be created in New Relic now!"

# --- INSTALL NR RESOURCES (e.g. alerts, SLOs) ---
echo "Installing New Relic demo resources..."
cd "${WORK_DIR}/opentelemetry-demo/newrelic/scripts"
./install-nr-resources.sh
echo "✅ Demo resources installed!"

# --- EXPOSE FRONTEND SERVICE ---
echo "Exposing frontend service on port 30080..."
kubectl patch svc frontend-proxy -n opentelemetry-demo -p '{"spec":{"type":"NodePort","ports":[{"port":8080,"targetPort":8080,"nodePort":30080,"protocol":"TCP"}]}}'
echo "✅ Frontend is now accessible on port 30080"

# --- PROMPT SCRIPT SETUP (TODO: bake this script into a custom image) ---
# Create ONE generic prompt script that works for ALL challenges
echo "Setting up generic prompt script to accept answers..."
cat > /tmp/generic_prompt <<'EOF'
#!/bin/bash
# Generic answer submission script for M.A.R.S. Program challenges
# Uses /tmp/answers.json for all challenges (cleaned up between challenges)

ANSWER_FILE="/tmp/answers.json"

echo "╔══════════════════════════════════════════════════════════════════╗"
echo "║  M.A.R.S. Program - Answer Submission                            ║"
echo "╚══════════════════════════════════════════════════════════════════╝"
echo ""
echo "📝 Read the assignment instructions to understand what to submit."
echo ""

# Show current answer if exists
if [[ -f "$ANSWER_FILE" ]]; then
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📋 Your Current Answer:"
    echo ""
    CURRENT=$(jq -r '.answer // "Not entered"' "$ANSWER_FILE" 2>/dev/null || echo "Not entered")
    echo "  $CURRENT"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
fi

# Continuous submission loop
while true; do
    echo "Enter your answer (or press Ctrl+C to exit):"
    read -p "> " ANSWER

    if [[ -n "$ANSWER" ]]; then
        echo "{\"answer\": \"$ANSWER\"}" > "$ANSWER_FILE"
        echo ""
        echo "✅ Answer saved!"
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "📌 Next Steps:"
        echo "   1️⃣  Click the 'Check' button in Instruqt to validate"
        echo "   2️⃣  To update your answer, just type a new one above"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "Current answer: $ANSWER"
        echo ""
    else
        echo "❌ Answer cannot be empty. Please try again."
        echo ""
    fi
done
EOF

chmod +x /tmp/generic_prompt
echo "✅ Generic prompt ready at /tmp/generic_prompt"

