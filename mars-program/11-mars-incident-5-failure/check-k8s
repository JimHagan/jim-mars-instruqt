#!/bin/bash
set -euo pipefail

# Expected answers (lowercase for case-insensitive comparison)
EXPECTED_SERVICE="cart"
EXPECTED_BACKING_STORE="valkey"
EXPECTED_EXCEPTION_NAME="Payment request failed. Invalid token. app.loyalty.level=gold"

# Alternative acceptable answers
ALT_SERVICE_ANSWERS=("cart service" "cart-service" "cartservice" "shopping cart")
ALT_BACKING_STORE_ANSWERS=("redis" "valkey" "valkey/redis" "redis/valkey" "cache" "backing store" "data store" "in-memory store")
ALT_EXPECTED_EXCEPTION_NAME_ANSWERS=("Invalid token" "Payment request failed" "invalid token" "payment failed")

# Normalize string: lowercase, trim whitespace
normalize() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | xargs
}

# Check if answer matches expected or alternatives
check_answer() {
    local answer="$1"
    local expected="$2"
    shift 2
    local alternatives=("$@")

    local normalized_answer=$(normalize "$answer")
    local normalized_expected=$(normalize "$expected")

    if [[ "$normalized_answer" == "$normalized_expected" ]]; then
        return 0
    fi

    for alt in "${alternatives[@]}"; do
        local normalized_alt=$(normalize "$alt")
        if [[ "$normalized_answer" == "$normalized_alt" ]]; then
            return 0
        fi
    done

    return 1
}

ANSWER_FILE="/tmp/answers.json"
if [[ ! -f "$ANSWER_FILE" ]]; then
    fail-message "❌ No answers submitted yet. Please enter your answers in the Check terminal."
    exit 1
fi

FULL_ANSWER=$(jq -r '.answer // empty' "$ANSWER_FILE")

if [[ -z "$FULL_ANSWER" ]]; then
    fail-message "❌ Answer cannot be empty."
    exit 1
fi

IFS=';' read -ra ANSWERS <<< "$FULL_ANSWER"

if [[ ${#ANSWERS[@]} -ne 3 ]]; then
    fail-message "❌ Invalid format. Please enter 3 answers separated by semi-colons: failing service; backing store; blocked customer action"
    exit 1
fi

SERVICE_ANSWER=$(echo "${ANSWERS[0]}" | xargs)
BACKING_STORE_ANSWER=$(echo "${ANSWERS[1]}" | xargs)
EXCEPTION_NAME_ANSWER=$(echo "${ANSWERS[2]}" | xargs)

if [[ -z "$SERVICE_ANSWER" ]] || [[ -z "$BACKING_STORE_ANSWER" ]] || [[ -z "$EXCEPTION_NAME_ANSWER" ]]; then
    fail-message "❌ All three parts must be filled. Format: failing service; backing store; blocked customer action"
    exit 1
fi

SERVICE_CORRECT=false
BACKING_STORE_CORRECT=false
USER_ACTION_CORRECT=false

check_answer "$SERVICE_ANSWER" "$EXPECTED_SERVICE" "${ALT_SERVICE_ANSWERS[@]}" && SERVICE_CORRECT=true
check_answer "$BACKING_STORE_ANSWER" "$EXPECTED_BACKING_STORE" "${ALT_BACKING_STORE_ANSWERS[@]}" && BACKING_STORE_CORRECT=true
check_answer "$EXCEPTION_NAME_ANSWER" "$EXPECTED_EXCEPTION_NAME" "${ALT_EXPECTED_EXCEPTION_NAME_ANSWERS[@]}" && EXCEPTION_NAME_CORRECT=true

if $SERVICE_CORRECT && $BACKING_STORE_CORRECT && $EXCEPTION_NAME_CORRECT; then
    echo "✅ All answers correct! Incident resolved."
    echo "🎯 $SERVICE_ANSWER cannot reach $BACKING_STORE_ANSWER — customers cannot $USER_ACTION_ANSWER"
    exit 0
else
    CORRECT_COUNT=0
    $SERVICE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $BACKING_STORE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $EXCEPTION_NAME_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    fail-message "❌ Not all answers are correct ($CORRECT_COUNT/3). Check your investigation and try again. Format: failing service; backing store; blocked customer action"
    exit 1
fi
