#!/bin/bash
set -uo pipefail

echo "=== Cleaning up Incident 6: Recommendation Cache Memory Leak ==="

rm -f /tmp/answers.json

echo "Disabling recommendationCacheFailure feature flag..."

CONFIGMAP_NAME=$(kubectl get configmap -n opentelemetry-demo -l app.kubernetes.io/component=flagd -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")

if [ -n "$CONFIGMAP_NAME" ]; then
  echo "Found ConfigMap: $CONFIGMAP_NAME"

  kubectl get configmap $CONFIGMAP_NAME -n opentelemetry-demo -o json | \
    jq '.data["demo.flagd.json"] | fromjson | .flags.recommendationCacheFailure.defaultVariant = "off" | .flags.recommendationCacheFailure.state = "DISABLED" | tojson' | \
    kubectl patch configmap $CONFIGMAP_NAME -n opentelemetry-demo --type merge -p "{\"data\":{\"demo.flagd.json\":$(cat)}}"

  echo "Restarting flagd pod to apply changes..."
  kubectl delete pod -n opentelemetry-demo -l app.kubernetes.io/component=flagd

  # Also restart the recommendation service to clear the leaked memory
  echo "Restarting recommendationservice to clear memory leak..."
  kubectl rollout restart deployment -n opentelemetry-demo -l app.kubernetes.io/name=recommendationservice 2>/dev/null || \
    kubectl delete pod -n opentelemetry-demo -l app.kubernetes.io/name=recommendationservice 2>/dev/null || true

  echo "✅ Feature flag disabled and memory cleared"
else
  echo "Warning: Could not find flagd ConfigMap, skipping flag cleanup"
fi

echo "✅ Cleanup complete"
