#!/bin/bash
set -uo pipefail  # Remove -e so script continues on errors

# Store the working directory
WORK_DIR="$(pwd)"

# Set up parameters (see config.yml for other env variables)
export TF_VAR_newrelic_api_key="${MARS_GAMEDAY_API_KEY}"
export TF_VAR_subaccount_name="${NR_SUBACCOUNT_NAME_PREFIX} ${INSTRUQT_PARTICIPANT_ID}"
export TF_VAR_readonly_user_name="${INSTRUQT_PARTICIPANT_ID} - User"
export TF_VAR_readonly_user_email="${INSTRUCTOR_EMAIL_HANDLE}+${INSTRUQT_PARTICIPANT_ID}@${INSTRUCTOR_EMAIL_DOMAIN}"
export TF_VAR_newrelic_account_id=$(cd "${WORK_DIR}/opentelemetry-demo/newrelic/terraform/nr_account" && terraform output -raw account_id)

# --- DELETE WORKLOAD CREATED DURING TRACK ---
echo "🧹 Cleaning up New Relic workloads..."

# Get credentials
NR_API_KEY="${MARS_GAMEDAY_API_KEY}"
NR_ACCOUNT_ID="${TF_VAR_newrelic_account_id}"
WORKLOAD_GUID_FILE="/tmp/mars_workload_guid"

if [[ -n "$NR_API_KEY" ]] && [[ -n "$NR_ACCOUNT_ID" ]] && [[ -f "$WORKLOAD_GUID_FILE" ]]; then
    WORKLOAD_GUID=$(cat "$WORKLOAD_GUID_FILE")

    if [[ -n "$WORKLOAD_GUID" ]] && [[ "$WORKLOAD_GUID" != "null" ]]; then
        echo "  Deleting workload (GUID: $WORKLOAD_GUID)..."

        # Use workloadDelete mutation (only takes guid)
        DELETE_WORKLOAD_MUTATION='mutation($guid: EntityGuid!) {
          workloadDelete(guid: $guid) {
            guid
          }
        }'

        DELETE_WORKLOAD_REQUEST=$(jq -n \
          --arg query "$DELETE_WORKLOAD_MUTATION" \
          --arg guid "$WORKLOAD_GUID" \
          '{query: $query, variables: {guid: $guid}}')

        DELETE_WORKLOAD_RESPONSE=$(curl -s -X POST https://api.newrelic.com/graphql \
          -H "Content-Type: application/json" \
          -H "API-Key: ${NR_API_KEY}" \
          -d "$DELETE_WORKLOAD_REQUEST")

        if echo "$DELETE_WORKLOAD_RESPONSE" | jq -e '.errors' > /dev/null 2>&1; then
            ERROR_MSG=$(echo "$DELETE_WORKLOAD_RESPONSE" | jq -r '.errors[0].message')
            echo "  ⚠️  Failed to delete workload: $ERROR_MSG"
        else
            echo "  ✅ Deleted workload successfully"
            # Clean up the file after successful deletion
            rm -f "$WORKLOAD_GUID_FILE"
        fi

        echo "✅ Workloads cleanup complete"
    else
        echo "  No valid workload GUID found in file"
    fi
else
    if [[ -z "$NR_API_KEY" ]]; then
        echo "  New Relic credentials not found, skipping workload cleanup"
    elif [[ -z "$NR_ACCOUNT_ID" ]]; then
        echo "  New Relic account ID not found, skipping workload cleanup"
    else
        echo "  No workload GUID file found ($WORKLOAD_GUID_FILE), skipping workload cleanup"
    fi
fi

# Destroy browser
echo "🧹 Destroying browser app..."
if cd "${WORK_DIR}/opentelemetry-demo/newrelic/terraform/nr_browser"; then
    terraform destroy -auto-approve # TODO: Getting "The agent must not have reporting data for 12 hours before deletion is permitted", although the rest of the detroys (including account) work
else
    echo "  ⚠️  Could not change to browser terraform directory, skipping"
fi

# Clean up the rest
echo "🧹 Running demo cleanup scripts..."
if cd "${WORK_DIR}/opentelemetry-demo/newrelic/scripts"; then
    ./cleanup-k8s.sh
    ./cleanup-nr-resources.sh
    ./cleanup-nr-account.sh
else
    echo "  ⚠️  Could not change to scripts directory, skipping"
fi

echo "✅ Track cleanup complete"