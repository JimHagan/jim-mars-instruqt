#!/bin/bash
set -uo pipefail

echo "=== Cleaning up Incident 7: Ad Service High CPU ==="

rm -f /tmp/answers.json

echo "Disabling adHighCpu feature flag..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read' 2>/dev/null || echo "")

if [ -n "$CURRENT_CONFIG" ]; then
  # Update the adHighCpu flag to disable it
  UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .adHighCpu.defaultVariant = "off" | .adHighCpu.state = "DISABLED")}}')

  # Write the updated config back via API
  curl -s -X POST 'http://localhost:30400/api/write' \
    -H 'Accept: */*' \
    -H 'Content-Type: application/json' \
    -H 'Pragma: no-cache' \
    --data-raw "$UPDATED_CONFIG" \
    --insecure >/dev/null 2>&1 || echo "Warning: Failed to update feature flags via API"

  echo "✅ Feature flag disabled"
else
  echo "Warning: Could not retrieve flag configuration, skipping flag cleanup"
fi

echo "✅ Cleanup complete"
