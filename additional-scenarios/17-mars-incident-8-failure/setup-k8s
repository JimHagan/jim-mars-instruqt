#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 8: Kafka Queue Problems ==="

echo "Retrieving current feature flag configuration from API..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read')

if [ -z "$CURRENT_CONFIG" ]; then
  echo "ERROR: Failed to retrieve current feature flags"
  exit 1
fi

echo "Enabling kafkaQueueProblems feature flag via API..."

# Update the kafkaQueueProblems flag in the config (using "on" variant for 100x multiplier)
UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .kafkaQueueProblems.defaultVariant = "on" | .kafkaQueueProblems.state = "ENABLED")}}')

# Write the updated config back via API
curl -f -X POST 'http://localhost:30400/api/write' \
  -H 'Accept: */*' \
  -H 'Content-Type: application/json' \
  -H 'Pragma: no-cache' \
  --data-raw "$UPDATED_CONFIG" \
  --insecure || {
    echo "ERROR: Failed to update feature flags via API"
    exit 1
  }

echo "✅ Incident triggered! Kafka queue is now being flooded at 100x the normal message rate."
echo "Note: Allow 2-3 minutes for consumer lag to build up and become visible in metrics."
echo ""
