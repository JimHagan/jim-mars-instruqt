#!/bin/bash
set -uo pipefail

echo "=== Cleaning up Incident 8: Kafka Queue Problems ==="

rm -f /tmp/answers.json

echo "Disabling kafkaQueueProblems feature flag..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read' 2>/dev/null || echo "")

if [ -n "$CURRENT_CONFIG" ]; then
  # Update the kafkaQueueProblems flag to disable it (reset to "off" variant)
  UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .kafkaQueueProblems.defaultVariant = "off" | .kafkaQueueProblems.state = "DISABLED")}}')

  # Write the updated config back via API
  curl -s -X POST 'http://localhost:30400/api/write' \
    -H 'Accept: */*' \
    -H 'Content-Type: application/json' \
    -H 'Pragma: no-cache' \
    --data-raw "$UPDATED_CONFIG" \
    --insecure >/dev/null 2>&1 || echo "Warning: Failed to update feature flags via API"

  echo "✅ Feature flag disabled — consumer lag will drain gradually"
else
  echo "Warning: Could not retrieve flag configuration, skipping flag cleanup"
fi

echo "✅ Cleanup complete"
