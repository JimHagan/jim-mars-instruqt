#!/bin/bash
set -uo pipefail

echo "=== Cleaning up Incident 9: Failed Readiness Probe ==="

rm -f /tmp/answers.json

echo "Disabling failedReadinessProbe feature flag..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read' 2>/dev/null || echo "")

if [ -n "$CURRENT_CONFIG" ]; then
  # Update the failedReadinessProbe flag to disable it
  UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .failedReadinessProbe.defaultVariant = "off" | .failedReadinessProbe.state = "DISABLED")}}')

  # Write the updated config back via API
  curl -s -X POST 'http://localhost:30400/api/write' \
    -H 'Accept: */*' \
    -H 'Content-Type: application/json' \
    -H 'Pragma: no-cache' \
    --data-raw "$UPDATED_CONFIG" \
    --insecure >/dev/null 2>&1 || echo "Warning: Failed to update feature flags via API"

  # Allow time for the flag change to propagate before restarting the cartservice
  sleep 5

  # Force a restart of the cartservice pod to clear any NotReady state
  echo "Restarting cartservice pod to restore readiness..."
  kubectl delete pod -n opentelemetry-demo -l app.kubernetes.io/name=cartservice 2>/dev/null || true

  echo "✅ Feature flag disabled and cartservice pod restarted"
else
  echo "Warning: Could not retrieve flag configuration, skipping flag cleanup"
fi

echo "✅ Cleanup complete"
