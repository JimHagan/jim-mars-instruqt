#!/bin/bash
set -euo pipefail

# Expected answers (lowercase for case-insensitive comparison)
EXPECTED_SERVICE="payment"
ERROR_RATE_MIN=20
ERROR_RATE_MAX=30
EXPECTED_TRANSACTION="charge"

# Alternative acceptable answers
ALT_SERVICE_ANSWERS=("payment service" "payment-service" "payment" "payments")
ALT_TRANSACTION_ANSWERS=("charge failed" "chargecard" "charge card" "payment charge" "charging" "chargecard rpc" "grpc.oteldemo.PaymentService/Charge")

# Normalize string: lowercase, trim whitespace
normalize() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | xargs
}

# Check if answer matches expected or alternatives
check_answer() {
    local answer="$1"
    local expected="$2"
    shift 2
    local alternatives=("$@")

    local normalized_answer=$(normalize "$answer")
    local normalized_expected=$(normalize "$expected")

    # Check exact match
    if [[ "$normalized_answer" == "$normalized_expected" ]]; then
        return 0
    fi

    # Check alternatives
    for alt in "${alternatives[@]}"; do
        local normalized_alt=$(normalize "$alt")
        if [[ "$normalized_answer" == "$normalized_alt" ]]; then
            return 0
        fi
    done

    return 1
}

# Check if an error rate answer falls within the acceptable range (20–30%).
# Accepts: plain integers (25), decimals (24.8), % suffix (25%, ~25%),
# and prose like "about 25%" or "approximately 25".
check_error_rate_range() {
    local raw
    raw=$(echo "$1" | tr '[:upper:]' '[:lower:]' | xargs)

    # Strip leading ~ and common prose prefixes
    raw="${raw#\~}"
    raw=$(echo "$raw" | sed 's/^about //; s/^approximately //; s/^around //')

    # Extract the leading numeric value (integer or decimal)
    local num
    num=$(echo "$raw" | grep -oE '^[0-9]+(\.[0-9]+)?')

    if [[ -z "$num" ]]; then
        return 1
    fi

    # Round to nearest integer via bc
    local rounded
    rounded=$(echo "($num + 0.5) / 1" | bc)

    (( rounded >= ERROR_RATE_MIN && rounded <= ERROR_RATE_MAX ))
}

# Check if answer file exists
ANSWER_FILE="/tmp/answers.json"
if [[ ! -f "$ANSWER_FILE" ]]; then
    fail-message "❌ No answers submitted yet. Please enter your answers in the Check terminal."
    exit 1
fi

# Read answer from JSON file (format: {"answer": "part1; part2; part3"})
FULL_ANSWER=$(jq -r '.answer // empty' "$ANSWER_FILE")

# Check if answer is empty
if [[ -z "$FULL_ANSWER" ]]; then
    fail-message "❌ Answer cannot be empty."
    exit 1
fi

# Parse semi-colon separated answer
IFS=';' read -ra ANSWERS <<< "$FULL_ANSWER"

# Check if we have exactly 3 parts
if [[ ${#ANSWERS[@]} -ne 3 ]]; then
    fail-message "❌ Invalid format. Please enter 3 answers separated by semi-colons: failing service; approximate error rate; failing transaction type"
    exit 1
fi

# Extract and trim each answer
SERVICE_ANSWER=$(echo "${ANSWERS[0]}" | xargs)
ERROR_RATE_ANSWER=$(echo "${ANSWERS[1]}" | xargs)
TRANSACTION_ANSWER=$(echo "${ANSWERS[2]}" | xargs)

# Check if any part is empty
if [[ -z "$SERVICE_ANSWER" ]] || [[ -z "$ERROR_RATE_ANSWER" ]] || [[ -z "$TRANSACTION_ANSWER" ]]; then
    fail-message "❌ All three parts must be filled. Format: failing service; approximate error rate; failing transaction type"
    exit 1
fi

# Validate each answer
SERVICE_CORRECT=false
ERROR_RATE_CORRECT=false
TRANSACTION_CORRECT=false

if check_answer "$SERVICE_ANSWER" "$EXPECTED_SERVICE" "${ALT_SERVICE_ANSWERS[@]}"; then
    SERVICE_CORRECT=true
fi

if check_error_rate_range "$ERROR_RATE_ANSWER"; then
    ERROR_RATE_CORRECT=true
fi

if check_answer "$TRANSACTION_ANSWER" "$EXPECTED_TRANSACTION" "${ALT_TRANSACTION_ANSWERS[@]}"; then
    TRANSACTION_CORRECT=true
fi

# Final result
if $SERVICE_CORRECT && $ERROR_RATE_CORRECT && $TRANSACTION_CORRECT; then
    echo "✅ All answers correct! Incident resolved."
    echo "🎯 $SERVICE_ANSWER is failing ~$ERROR_RATE_ANSWER of $TRANSACTION_ANSWER transactions"
    exit 0
else
    CORRECT_COUNT=0
    $SERVICE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $ERROR_RATE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $TRANSACTION_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))

    fail-message "❌ Not all answers are correct ($CORRECT_COUNT/3). Check your investigation and try again. Format: failing service; approximate error rate; failing transaction type (error rate should be a percentage between $ERROR_RATE_MIN–$ERROR_RATE_MAX%)"
    exit 1
fi
