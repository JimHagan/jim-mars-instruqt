#!/bin/bash
set -uo pipefail  # No -e flag, script continues on errors

echo "=== Cleaning up Incident 3: Image Slow Load ==="

# Clean up answer file
rm -f /tmp/answers.json

echo "Disabling imageSlowLoad feature flag..."

# Update the flagd-config ConfigMap to set imageSlowLoad defaultVariant back to "off"
kubectl get configmap flagd-config -n opentelemetry-demo -o json 2>/dev/null | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.imageSlowLoad.defaultVariant = "off" | tojson)' | \
  kubectl apply -f - >/dev/null 2>&1 || {
    echo "Warning: Failed to update flagd ConfigMap"
  }

# Restart flagd deployment
kubectl rollout restart deployment flagd -n opentelemetry-demo >/dev/null 2>&1 || {
  echo "Warning: Failed to restart flagd deployment"
}

# Wait for flagd rollout (with short timeout for cleanup)
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=30s >/dev/null 2>&1 || {
  echo "Warning: flagd rollout did not complete in time"
}

# Restart frontend deployment
kubectl rollout restart deployment frontend -n opentelemetry-demo >/dev/null 2>&1 || {
  echo "Warning: Failed to restart frontend deployment"
}

# Wait for frontend rollout (with short timeout for cleanup)
kubectl rollout status deployment frontend -n opentelemetry-demo --timeout=30s >/dev/null 2>&1 || {
  echo "Warning: frontend rollout did not complete in time"
}

echo "✅ Feature flag disabled"

echo "✅ Cleanup complete"
