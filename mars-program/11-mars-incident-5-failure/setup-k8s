#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 5: Cart Service Failure ==="

echo "Retrieving current feature flag configuration from API..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read')

if [ -z "$CURRENT_CONFIG" ]; then
  echo "ERROR: Failed to retrieve current feature flags"
  exit 1
fi

echo "Enabling cartFailure feature flag via API..."

# Update the cartFailure flag in the config
UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .cartFailure.defaultVariant = "on" | .cartFailure.state = "ENABLED")}}')

# Write the updated config back via API
curl -f -X POST 'http://localhost:30400/api/write' \
  -H 'Accept: */*' \
  -H 'Content-Type: application/json' \
  -H 'Pragma: no-cache' \
  --data-raw "$UPDATED_CONFIG" \
  --insecure || {
    echo "ERROR: Failed to update feature flags via API"
    exit 1
  }

echo "✅ Incident triggered! Cart service will now fail."
echo ""
