#!/bin/bash
set -uo pipefail  # No -e flag, script continues on errors

echo "🧹 Cleaning up intro..."

# Get workload name (team name) from answer file
ANSWER_FILE="/tmp/answers.json"
WORKLOAD_NAME=$(jq -r '.answer // empty' "$ANSWER_FILE" 2>/dev/null)

# Clean up answer file
rm -f /tmp/answers.json
echo "✅ Answer file cleaned up"

echo "🏷️  Tagging entities with team name: $WORKLOAD_NAME"

# Get credentials
NR_API_KEY="${MARS_GAMEDAY_API_KEY}"
NR_ACCOUNT_ID=$(cd opentelemetry-demo/newrelic/terraform/nr_account && terraform output -raw account_id 2>/dev/null)

# Fetch all entities in the account
ENTITIES_QUERY=$(cat <<'GQL'
{
  actor {
    entitySearch(query: "accountId = %ACCOUNT_ID%") {
      results {
        entities {
          guid
        }
      }
    }
  }
}
GQL
)

ENTITIES_QUERY="${ENTITIES_QUERY//%ACCOUNT_ID%/$NR_ACCOUNT_ID}"

ENTITIES_RESPONSE=$(curl -s -X POST https://api.newrelic.com/graphql \
  -H "Content-Type: application/json" \
  -H "API-Key: ${NR_API_KEY}" \
  -d "{\"query\": $(echo "$ENTITIES_QUERY" | jq -Rs .)}")

ENTITIES=$(echo "$ENTITIES_RESPONSE" | jq -r '.data.actor.entitySearch.results.entities // []')
ENTITY_COUNT=$(echo "$ENTITIES" | jq 'length')

if [[ "$ENTITY_COUNT" -gt 0 ]]; then
    echo "  Found $ENTITY_COUNT entities to tag"

    # Get all entity GUIDs
    ALL_GUIDS=$(echo "$ENTITIES" | jq -r '[.[].guid]')

    # Tag in batches of 50 entities
    BATCH_SIZE=50
    NUM_BATCHES=$(echo "$ALL_GUIDS" | jq --arg size "$BATCH_SIZE" 'length / ($size | tonumber) | ceil')
    TOTAL_TAGGED=0

    echo "  Tagging entities in $NUM_BATCHES batch(es)..."

    for ((batch=0; batch<NUM_BATCHES; batch++)); do
        OFFSET=$((batch * BATCH_SIZE))
        BATCH_GUIDS=$(echo "$ALL_GUIDS" | jq --arg offset "$OFFSET" --arg size "$BATCH_SIZE" '.[$offset | tonumber : ($offset | tonumber) + ($size | tonumber)]')
        BATCH_COUNT=$(echo "$BATCH_GUIDS" | jq 'length')

        # Build mutation for this batch
        TAG_MUTATION="mutation {
$(echo "$BATCH_GUIDS" | jq -r --arg teamName "$WORKLOAD_NAME" 'to_entries | map("  tag\(.key): taggingAddTagsToEntity(guid: \"\(.value)\", tags: [{key: \"team\", values: [\"\($teamName)\"]}]) { errors { message } }") | join("\n")')
}"

        TAG_REQUEST=$(jq -n --arg query "$TAG_MUTATION" '{query: $query}')

        TAG_RESPONSE=$(curl -s -X POST https://api.newrelic.com/graphql \
          -H "Content-Type: application/json" \
          -H "API-Key: ${NR_API_KEY}" \
          -d "$TAG_REQUEST")

        # Check for errors but don't fail
        if echo "$TAG_RESPONSE" | jq -e '.errors' > /dev/null 2>&1; then
            ERROR_MSG=$(echo "$TAG_RESPONSE" | jq -r '.errors[0].message')
            echo "  ⚠️  Batch $((batch + 1)) had errors: $ERROR_MSG"
        else
            TOTAL_TAGGED=$((TOTAL_TAGGED + BATCH_COUNT))
            echo "  ✅ Batch $((batch + 1))/$NUM_BATCHES complete"
        fi
    done

    echo "✅ Tagged $TOTAL_TAGGED entities with team: $WORKLOAD_NAME"
else
    echo "  No entities found to tag"
fi

echo "✅ Cleanup complete"