#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 7: Ad Service High CPU ==="

echo "Retrieving current feature flag configuration from API..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read')

if [ -z "$CURRENT_CONFIG" ]; then
  echo "ERROR: Failed to retrieve current feature flags"
  exit 1
fi

echo "Enabling adHighCpu feature flag via API..."

# Update the adHighCpu flag in the config
UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .adHighCpu.defaultVariant = "on" | .adHighCpu.state = "ENABLED")}}')

# Write the updated config back via API
curl -f -X POST 'http://localhost:30400/api/write' \
  -H 'Accept: */*' \
  -H 'Content-Type: application/json' \
  -H 'Pragma: no-cache' \
  --data-raw "$UPDATED_CONFIG" \
  --insecure || {
    echo "ERROR: Failed to update feature flags via API"
    exit 1
  }

echo "✅ Incident triggered! Ad service CPU load is now elevated."
echo "Note: Allow 1-2 minutes for CPU metrics to become clearly visible in New Relic."
echo ""
