#!/bin/bash
set -uo pipefail

echo "=== Cleaning up Incident 6: Recommendation Cache Memory Leak ==="

rm -f /tmp/answers.json

echo "Disabling recommendationCacheFailure feature flag..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read' 2>/dev/null || echo "")

if [ -n "$CURRENT_CONFIG" ]; then
  # Update the recommendationCacheFailure flag to disable it
  UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .recommendationCacheFailure.defaultVariant = "off" | .recommendationCacheFailure.state = "DISABLED")}}')

  # Write the updated config back via API
  curl -s -X POST 'http://localhost:30400/api/write' \
    -H 'Accept: */*' \
    -H 'Content-Type: application/json' \
    -H 'Pragma: no-cache' \
    --data-raw "$UPDATED_CONFIG" \
    --insecure >/dev/null 2>&1 || echo "Warning: Failed to update feature flags via API"

  # Also restart the recommendation service to clear the leaked memory
  echo "Restarting recommendationservice to clear memory leak..."
  kubectl rollout restart deployment -n opentelemetry-demo -l app.kubernetes.io/name=recommendationservice 2>/dev/null || \
    kubectl delete pod -n opentelemetry-demo -l app.kubernetes.io/name=recommendationservice 2>/dev/null || true

  echo "✅ Feature flag disabled and memory cleared"
else
  echo "Warning: Could not retrieve flag configuration, skipping flag cleanup"
fi

echo "✅ Cleanup complete"
