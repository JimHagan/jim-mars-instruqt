#!/bin/bash
set -euo pipefail

# Define account name for validation messages
ACCOUNT_NAME="${NR_SUBACCOUNT_NAME_PREFIX} ${INSTRUQT_PARTICIPANT_ID}"

# Check if answer file exists
ANSWER_FILE="/tmp/answers.json"
if [[ ! -f "$ANSWER_FILE" ]]; then
    fail-message "❌ No workload name submitted yet. Please enter your workload name in the Check terminal."
    exit 1
fi

# Read workload name from JSON file
WORKLOAD_NAME=$(jq -r '.answer // empty' "$ANSWER_FILE")

# Check if workload name is empty
if [[ -z "$WORKLOAD_NAME" ]]; then
    fail-message "❌ Workload name cannot be empty."
    exit 1
fi

# Get New Relic credentials from environment
NR_API_KEY="${MARS_GAMEDAY_API_KEY}"
NR_ACCOUNT_ID=$(cd opentelemetry-demo/newrelic/terraform/nr_account && terraform output -raw account_id)

if [[ -z "$NR_API_KEY" ]] || [[ -z "$NR_ACCOUNT_ID" ]]; then
    fail-message "❌ New Relic credentials not found in environment."
    exit 1
fi

echo "🔍 Searching for workload '$WORKLOAD_NAME'..."

# GraphQL query to search for workload using entitySearch
# Use accountId (not tags.accountId) to scope to the specific account
WORKLOAD_QUERY=$(cat <<'GQL'
{
  actor {
    entitySearch(query: "accountId = %ACCOUNT_ID% AND type = 'WORKLOAD' AND name = '%WORKLOAD_NAME%'") {
      results {
        entities {
          guid
          name
        }
      }
    }
  }
}
GQL
)

# Replace placeholders
WORKLOAD_QUERY="${WORKLOAD_QUERY//%WORKLOAD_NAME%/$WORKLOAD_NAME}"
WORKLOAD_QUERY="${WORKLOAD_QUERY//%ACCOUNT_ID%/$NR_ACCOUNT_ID}"

# Make GraphQL request to get workload
RESPONSE=$(curl -s -X POST https://api.newrelic.com/graphql \
  -H "Content-Type: application/json" \
  -H "API-Key: ${NR_API_KEY}" \
  -d "{\"query\": $(echo "$WORKLOAD_QUERY" | jq -Rs .)}")

# Check for errors
if echo "$RESPONSE" | jq -e '.errors' > /dev/null 2>&1; then
    ERROR_MSG=$(echo "$RESPONSE" | jq -r '.errors[0].message // "Unknown error"')
    fail-message "❌ New Relic API error: $ERROR_MSG"
    exit 1
fi

# Check if workload exists
WORKLOAD_COUNT=$(echo "$RESPONSE" | jq -r '.data.actor.entitySearch.results.entities | length')

if [[ "$WORKLOAD_COUNT" == "0" ]]; then
    fail-message "❌ Workload '$WORKLOAD_NAME' not found in account $NR_ACCOUNT_ID. Please check the name (case-sensitive)."
    exit 1
fi

WORKLOAD_GUID=$(echo "$RESPONSE" | jq -r '.data.actor.entitySearch.results.entities[0].guid')

echo "✅ Found workload: $WORKLOAD_NAME"
echo "🔍 Validating workload configuration..."

# Validate that the workload is configured with the correct query
WORKLOAD_CONFIG_QUERY=$(cat <<'GQL'
{
  actor {
    account(id: %ACCOUNT_ID%) {
      workload {
        collection(guid: "%WORKLOAD_GUID%") {
          guid
          name
          entitySearchQueries {
            query
          }
          scopeAccounts {
            accountIds
          }
        }
      }
    }
  }
}
GQL
)

WORKLOAD_CONFIG_QUERY="${WORKLOAD_CONFIG_QUERY//%ACCOUNT_ID%/$NR_ACCOUNT_ID}"
WORKLOAD_CONFIG_QUERY="${WORKLOAD_CONFIG_QUERY//%WORKLOAD_GUID%/$WORKLOAD_GUID}"

CONFIG_RESPONSE=$(curl -s -X POST https://api.newrelic.com/graphql \
  -H "Content-Type: application/json" \
  -H "API-Key: ${NR_API_KEY}" \
  -d "{\"query\": $(echo "$WORKLOAD_CONFIG_QUERY" | jq -Rs .)}")

# Check for errors
if echo "$CONFIG_RESPONSE" | jq -e '.errors' > /dev/null 2>&1; then
    ERROR_MSG=$(echo "$CONFIG_RESPONSE" | jq -r '.errors[0].message // "Unknown error"')
    fail-message "❌ Error fetching workload configuration: $ERROR_MSG"
    exit 1
fi

# Check if workload has a query configured
SEARCH_QUERIES=$(echo "$CONFIG_RESPONSE" | jq -r '.data.actor.account.workload.collection.entitySearchQueries // []')
QUERY_COUNT=$(echo "$SEARCH_QUERIES" | jq 'length')

if [[ "$QUERY_COUNT" == "0" ]]; then
    fail-message "❌ Workload '$WORKLOAD_NAME' has no query configured. Please add entities using a query like: \`tags.account\` = '$ACCOUNT_NAME' or tags.accountId = '$NR_ACCOUNT_ID'"
    exit 1
fi

# Check if workload query includes the account tag (either account name or account ID)
HAS_ACCOUNT_NAME=$(echo "$SEARCH_QUERIES" | jq --arg accountName "$ACCOUNT_NAME" '[.[] | select(.query | contains($accountName))] | length > 0')
HAS_ACCOUNT_ID=$(echo "$SEARCH_QUERIES" | jq --arg accountId "$NR_ACCOUNT_ID" '[.[] | select(.query | contains($accountId))] | length > 0')

if [[ "$HAS_ACCOUNT_NAME" != "true" ]] && [[ "$HAS_ACCOUNT_ID" != "true" ]]; then
    ACTUAL_QUERY=$(echo "$SEARCH_QUERIES" | jq -r '.[0].query')
    fail-message "❌ Workload query doesn't filter by account. Expected: \`tags.account\` = '$ACCOUNT_NAME' OR tags.accountId = '$NR_ACCOUNT_ID', but found: $ACTUAL_QUERY"
    exit 1
fi

echo "✅ Workload configuration validated successfully"

# Store workload GUID for cleanup
echo "$WORKLOAD_GUID" > /tmp/mars_workload_guid

# Success!
echo ""
echo "═══════════════════════════════════════════════════════════════════"
echo "✅ Perfect! Workload '$WORKLOAD_NAME' is properly configured!"
echo "🎯 Workload query validated successfully"
echo "═══════════════════════════════════════════════════════════════════"
exit 0