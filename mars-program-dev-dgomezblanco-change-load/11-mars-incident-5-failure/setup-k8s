#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 6: Recommendation Cache Memory Leak ==="

echo "Updating flagd ConfigMap to enable recommendationCacheFailure..."

# Update the flagd-config ConfigMap to set recommendationCacheFailure defaultVariant to "on"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.recommendationCacheFailure.defaultVariant = "on" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting recommendation deployment to refresh flag cache..."
kubectl rollout restart deployment recommendation -n opentelemetry-demo

echo "Waiting for recommendation rollout to complete..."
kubectl rollout status deployment recommendation -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: recommendation rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! Recommendation service cache memory leak is now active."
echo "Note: Memory growth is gradual — allow a few minutes for it to become visible in metrics."
echo ""
