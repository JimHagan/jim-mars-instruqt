#!/bin/bash
set -euo pipefail

# Expected answers (lowercase for case-insensitive comparison)
EXPECTED_SERVICE="product-catalog"
EXPECTED_PRODUCT="oljcespc7z"
EXPECTED_EXCEPTION_TEXT="Error: Product Catalog Fail Feature Flag Enabled"

# Alternative acceptable answers
ALT_SERVICE_ANSWERS=("product" "product-catalog" "catalog" "product catalog" "product-catalog-service" "productcatalog" "ProductCatalog")
ALT_PRODUCT_ANSWERS=("oljcespc7z" "OLJCESPC7Z" "product oljcespc7z" "product OLJCESPC7Z")
ALT_EXCEPTION_ANSWERS=("Error: Product Catalog Fail Feature Flag Enabled" "Product Catalog Fail" "Product Catalog Fail Feature Flag Enabled")

# Normalize string: lowercase, trim whitespace
normalize() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | xargs
}

# Check if answer matches expected or alternatives
check_answer() {
    local answer="$1"
    local expected="$2"
    shift 2
    local alternatives=("$@")

    local normalized_answer=$(normalize "$answer")
    local normalized_expected=$(normalize "$expected")

    # Check exact match
    if [[ "$normalized_answer" == "$normalized_expected" ]]; then
        return 0
    fi

    # Check alternatives
    for alt in "${alternatives[@]}"; do
        local normalized_alt=$(normalize "$alt")
        if [[ "$normalized_answer" == "$normalized_alt" ]]; then
            return 0
        fi
    done

    return 1
}

# Check if answer file exists
ANSWER_FILE="/tmp/answers.json"
if [[ ! -f "$ANSWER_FILE" ]]; then
    fail-message "❌ No answers submitted yet. Please enter your answers in the Check terminal."
    exit 1
fi

# Read answer from JSON file (format: {"answer": "part1; part2; part3"})
FULL_ANSWER=$(jq -r '.answer // empty' "$ANSWER_FILE")

# Check if answer is empty
if [[ -z "$FULL_ANSWER" ]]; then
    fail-message "❌ Answer cannot be empty."
    exit 1
fi

# Parse semi-colon separated answer
IFS=';' read -ra ANSWERS <<< "$FULL_ANSWER"

# Check if we have exactly 3 parts
if [[ ${#ANSWERS[@]} -ne 3 ]]; then
    fail-message "❌ Invalid format. Please enter 3 answers separated by semi-colons: affected service; affected product id; exception text"
    exit 1
fi

# Extract and trim each answer
SERVICE_ANSWER=$(echo "${ANSWERS[0]}" | xargs)
PRODUCT_ANSWER=$(echo "${ANSWERS[1]}" | xargs)
EXCEPTION_TEXT_ANSWER=$(echo "${ANSWERS[2]}" | xargs)

# Check if any part is empty
if [[ -z "$SERVICE_ANSWER" ]] || [[ -z "$PRODUCT_ANSWER" ]] || [[ -z "$EXCEPTION_TEXT_ANSWER" ]]; then
    fail-message "❌ All three parts must be filled. Format: affected service; affected product name; issue type"
    exit 1
fi

# Validate each answer
SERVICE_CORRECT=false
PRODUCT_CORRECT=false
ISSUE_TYPE_CORRECT=false

if check_answer "$SERVICE_ANSWER" "$EXPECTED_SERVICE" "${ALT_SERVICE_ANSWERS[@]}"; then
    SERVICE_CORRECT=true
fi

if check_answer "$PRODUCT_ANSWER" "$EXPECTED_PRODUCT" "${ALT_PRODUCT_ANSWERS[@]}"; then
    PRODUCT_CORRECT=true
fi

if check_answer "$EXCEPTION_TEXT_ANSWER" "$EXPECTED_EXCEPTION_TEXT" "${ALT_EXCEPTION_ANSWERS[@]}"; then
    ISSUE_TYPE_CORRECT=true
fi

# Final result
if $SERVICE_CORRECT && $PRODUCT_CORRECT && $ISSUE_TYPE_CORRECT; then
    echo "✅ All answers correct! Incident resolved."
    echo "🎯 $SERVICE_ANSWER is throwing $EXCEPTION_TEXT_ANSWER for product: $PRODUCT_ANSWER"
    exit 0
else
    CORRECT_COUNT=0
    $SERVICE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $PRODUCT_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))
    $ISSUE_TYPE_CORRECT && CORRECT_COUNT=$((CORRECT_COUNT + 1))

    fail-message "❌ Not all answers are correct ($CORRECT_COUNT/3). Check your investigation and try again. Format: affected service; affected product name; issue type"
    exit 1
fi
