#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 3: Image Slow Load ==="

echo "Updating flagd ConfigMap to enable imageSlowLoad..."

# Update the flagd-config ConfigMap to set imageSlowLoad defaultVariant to "5sec"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.imageSlowLoad.defaultVariant = "5sec" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting frontend deployment to refresh flag cache..."
kubectl rollout restart deployment frontend -n opentelemetry-demo

echo "Waiting for frontend rollout to complete..."
kubectl rollout status deployment frontend -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: frontend rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! Image loading is now artificially delayed."
echo ""
