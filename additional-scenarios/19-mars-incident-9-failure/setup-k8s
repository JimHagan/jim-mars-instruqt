#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 9: Failed Readiness Probe ==="

echo "Updating flagd ConfigMap to enable failedReadinessProbe..."

# Update the flagd-config ConfigMap to set failedReadinessProbe defaultVariant to "on"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.failedReadinessProbe.defaultVariant = "on" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting cart deployment to refresh flag cache..."
kubectl rollout restart deployment cart -n opentelemetry-demo

echo "Waiting for cart rollout to complete..."
kubectl rollout status deployment cart -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: cart rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! The cartservice readiness probe will now begin failing."
echo "Note: Allow 30-60 seconds for Kubernetes to detect the probe failure and remove the pod from rotation."
echo ""
