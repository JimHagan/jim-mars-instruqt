#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 8: Kafka Queue Problems ==="

echo "Updating flagd ConfigMap to enable kafkaQueueProblems..."

# Update the flagd-config ConfigMap to set kafkaQueueProblems defaultVariant to "on"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.kafkaQueueProblems.defaultVariant = "on" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting kafka deployment to refresh flag cache..."
kubectl rollout restart deployment kafka -n opentelemetry-demo

echo "Waiting for kafka rollout to complete..."
kubectl rollout status deployment kafka -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: kafka rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! Kafka queue is now being flooded at 100x the normal message rate."
echo "Note: Allow 2-3 minutes for consumer lag to build up and become visible in metrics."
echo ""
