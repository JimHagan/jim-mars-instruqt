#!/bin/bash
set -uo pipefail  # No -e flag, script continues on errors

echo "=== Cleaning up Incident 8: Kafka Queue Problems ==="

# Clean up answer file
rm -f /tmp/answers.json

echo "Disabling kafkaQueueProblems feature flag..."

# Update the flagd-config ConfigMap to set kafkaQueueProblems defaultVariant back to "off"
kubectl get configmap flagd-config -n opentelemetry-demo -o json 2>/dev/null | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.kafkaQueueProblems.defaultVariant = "off" | tojson)' | \
  kubectl apply -f - >/dev/null 2>&1 || {
    echo "Warning: Failed to update flagd ConfigMap"
  }

# Restart flagd deployment
kubectl rollout restart deployment flagd -n opentelemetry-demo >/dev/null 2>&1 || {
  echo "Warning: Failed to restart flagd deployment"
}

# Wait for flagd rollout (with short timeout for cleanup)
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=30s >/dev/null 2>&1 || {
  echo "Warning: flagd rollout did not complete in time"
}

# Restart kafka deployment
kubectl rollout restart deployment kafka -n opentelemetry-demo >/dev/null 2>&1 || {
  echo "Warning: Failed to restart kafka deployment"
}

# Wait for kafka rollout (with short timeout for cleanup)
kubectl rollout status deployment kafka -n opentelemetry-demo --timeout=30s >/dev/null 2>&1 || {
  echo "Warning: kafka rollout did not complete in time"
}

echo "✅ Feature flag disabled — consumer lag will drain gradually"

echo "✅ Cleanup complete"
