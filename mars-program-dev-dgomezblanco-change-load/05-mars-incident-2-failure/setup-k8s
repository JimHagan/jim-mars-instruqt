#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 2: Payment Service Unreachable ==="

echo "Updating flagd ConfigMap to enable paymentUnreachable..."

# Update the flagd-config ConfigMap to set paymentUnreachable defaultVariant to "on"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.paymentUnreachable.defaultVariant = "on" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting checkout deployment to refresh flag cache..."
kubectl rollout restart deployment checkout -n opentelemetry-demo

echo "Waiting for checkout rollout to complete..."
kubectl rollout status deployment checkout -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: checkout rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! Payment service is now unreachable."
echo ""
