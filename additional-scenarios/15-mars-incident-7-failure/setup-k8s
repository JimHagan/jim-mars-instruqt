#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 7: Ad Service High CPU ==="

echo "Updating flagd ConfigMap to enable adHighCpu..."

# Update the flagd-config ConfigMap to set adHighCpu defaultVariant to "on"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.adHighCpu.defaultVariant = "on" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting ad deployment to refresh flag cache..."
kubectl rollout restart deployment ad -n opentelemetry-demo

echo "Waiting for ad rollout to complete..."
kubectl rollout status deployment ad -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: ad rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! Ad service CPU load is now elevated."
echo "Note: Allow 1-2 minutes for CPU metrics to become clearly visible in New Relic."
echo ""
