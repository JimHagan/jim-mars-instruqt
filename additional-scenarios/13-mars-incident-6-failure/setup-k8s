#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 6: Recommendation Cache Memory Leak ==="

echo "Retrieving current feature flag configuration from API..."

# Get the current config from the API (flagd exposed on NodePort 30400)
CURRENT_CONFIG=$(curl -s 'http://localhost:30400/api/read')

if [ -z "$CURRENT_CONFIG" ]; then
  echo "ERROR: Failed to retrieve current feature flags"
  exit 1
fi

echo "Enabling recommendationCacheFailure feature flag via API..."

# Update the recommendationCacheFailure flag in the config
UPDATED_CONFIG=$(echo "$CURRENT_CONFIG" | jq '{data: {flags: (.flags | .recommendationCacheFailure.defaultVariant = "on" | .recommendationCacheFailure.state = "ENABLED")}}')

# Write the updated config back via API
curl -f -X POST 'http://localhost:30400/api/write' \
  -H 'Accept: */*' \
  -H 'Content-Type: application/json' \
  -H 'Pragma: no-cache' \
  --data-raw "$UPDATED_CONFIG" \
  --insecure || {
    echo "ERROR: Failed to update feature flags via API"
    exit 1
  }

echo "✅ Incident triggered! Recommendation service cache memory leak is now active."
echo "Note: Memory growth is gradual — allow a few minutes for it to become visible in metrics."
echo ""
