#!/bin/bash
set -euo pipefail

echo "=== Setting up Incident 4: Payment Service Failure ==="

echo "Updating flagd ConfigMap to enable paymentFailure..."

# Update the flagd-config ConfigMap to set paymentFailure defaultVariant to "25%"
kubectl get configmap flagd-config -n opentelemetry-demo -o json | \
  jq '.data["demo.flagd.json"] |= (fromjson | .flags.paymentFailure.defaultVariant = "25%" | tojson)' | \
  kubectl apply -f - || {
    echo "ERROR: Failed to update flagd ConfigMap"
    exit 1
  }

echo "Restarting flagd deployment to pick up new configuration..."
kubectl rollout restart deployment flagd -n opentelemetry-demo

echo "Waiting for flagd rollout to complete..."
kubectl rollout status deployment flagd -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: flagd rollout failed or timed out"
  exit 1
}

echo "Restarting payment deployment to refresh flag cache..."
kubectl rollout restart deployment payment -n opentelemetry-demo

echo "Waiting for payment rollout to complete..."
kubectl rollout status deployment payment -n opentelemetry-demo --timeout=60s || {
  echo "ERROR: payment rollout failed or timed out"
  exit 1
}

echo "✅ Incident triggered! Payment service will now intermittently fail charge requests."
echo ""
